Bootstrap: localimage
From: base.sif

%post
  mkdir -p /cache
  export TMPDIR=/cache

  pip install --no-cache-dir torch==2.8.0

  git clone https://github.com/ejaasaari/chamfer

  cd /chamfer
  git config --global --add safe.directory /chamfer
  git reset --hard 2a781d4de5605b00bcb8459670d16230d9491b75

  pip install .

  cd ..

  git clone https://github.com/ejaasaari/muvera

  cd /muvera
  git config --global --add safe.directory /muvera
  git reset --hard 4682ac93c543c1ebbce027619e3be2d79b2859e7

  pip install .

  cd ..

  git clone https://github.com/zilliztech/pyglass

  cd pyglass
  git config --global --add safe.directory /pyglass
  git reset --hard d2296ec447d2374ee8f88c6d3b85be1b1e434ad3

  pip install -v -e "python"